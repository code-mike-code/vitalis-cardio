# =============================================================
# Vitalis — przykładowy plik zmiennych środowiskowych
# Skopiuj jako .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env do repozytorium!
# =============================================================

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps — Place ID kliniki
# Znajdź na: https://developers.google.com/maps/documentation/javascript/place-id
VITE_GOOGLE_PLACE_ID=

# EmailJS — https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Kalendarz / system rezerwacji online
VITE_CALENDAR_EMBED_URL=
VITE_CALENDAR_API_KEY=
